<UserControl x:Class="Windwaker_coop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Status Bar -->
        <Border Grid.Row="0" Background="#1B5E20" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ConnectionInfo}"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#FFD700" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#4CAF50" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSyncing}" Value="False">
                                        <Setter Property="Fill" Value="#FF9800" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="13" />
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Stop"
                        Style="{StaticResource MaterialDesignFlatDarkBgButton}"
                        Command="{Binding StopCommand}"
                        Foreground="White"
                        Padding="16,4"
                        FontSize="12" />
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Log Panel -->
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding LogEntries}"
                     Background="Transparent"
                     BorderThickness="0"
                     Margin="8"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     x:Name="LogListBox"
>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                        <Setter Property="Padding" Value="8,2" />
                        <Setter Property="Focusable" Value="False" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Timestamp}"
                                       Foreground="#616161"
                                       FontSize="12"
                                       FontFamily="Consolas"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Message}"
                                       Foreground="{Binding ColorBrush}"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Player List (Server only) -->
            <Border Grid.Column="1"
                    Width="250"
                    Background="#1A1A1A"
                    BorderBrush="#333333"
                    BorderThickness="1,0,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsServerMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Connected Players"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="#4CAF50"
                               Margin="12,12,12,8" />

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding ConnectedPlayers}"
                             Background="Transparent"
                             BorderThickness="0"
                             Margin="4,0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                                <Setter Property="Padding" Value="8,6" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontSize="12"
                                           Foreground="#E0E0E0" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Command Input -->
        <Border Grid.Row="2" Background="#1A1A1A" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Type a command..."
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontFamily="Consolas"
                         FontSize="13"
                         Margin="0,0,8,0"
                         materialDesign:TextFieldAssist.HasClearButton="True">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SendCommandCommand}" />
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="1"
                        Content="{materialDesign:PackIcon Kind=Send}"
                        Style="{StaticResource MaterialDesignFlatMidBgButton}"
                        Command="{Binding SendCommandCommand}"
                        Padding="12" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
